{
  "name": "desktop-app",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop Electron client for Meet realtime feedback",
  "author": "Meet Team",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:electron\"",
    "dev:web": "next dev --port 3210",
    "dev:electron": "wait-on tcp:3210 && NEXT_DEV_SERVER_URL=http://localhost:3210 sh ./scripts/run-electron.sh",
    "build": "pnpm build:web && pnpm build:electron",
    "build:web": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "next start",
    "lint": "eslint",
    "desktop:start": "NODE_ENV=production sh ./scripts/run-electron.sh",
    "desktop:validate-protocol": "tsx scripts/validate-egress-protocol.ts",
    "desktop:test:phase7": "tsx scripts/phase7-parity-check.ts",
    "pack": "pnpm build && electron-builder --dir --config electron-builder.yml",
    "dist:mac": "pnpm build && electron-builder --mac --config electron-builder.yml",
    "dist:win": "pnpm build && electron-builder --win --config electron-builder.yml",
    "dist": "pnpm build && electron-builder -mwl --config electron-builder.yml"
  },
  "dependencies": {
    "active-win": "^9.0.0",
    "electron-updater": "^6.8.3",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
